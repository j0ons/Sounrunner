# Soun Al Hosn Assessment Runner
# Optional Fernet key for local encrypted evidence/checkpoints/session blobs.
# Generate:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SOUN_RUNNER_WORKSPACE_KEY=

# Optional AES ZIP bundle password. If unset, the session ID is used.
SOUN_RUNNER_BUNDLE_PASSWORD=

# Optional external runtime paths used by the Windows deployment scripts.
SOUN_RUNNER_DATA_DIR=C:\SounRunner\data
SOUN_RUNNER_LOG_DIR=C:\SounRunner\logs

# Optional SMTP settings for sanitized summary email.
SOUN_RUNNER_SMTP_HOST=
SOUN_RUNNER_SMTP_PORT=587
SOUN_RUNNER_SMTP_USERNAME=
SOUN_RUNNER_SMTP_PASSWORD=
SOUN_RUNNER_SMTP_FROM=
SOUN_RUNNER_SMTP_TO=

# Optional callback upload credentials. Configure providers in config.yaml.
SOUN_RUNNER_S3_ACCESS_KEY=
SOUN_RUNNER_S3_SECRET_KEY=
SOUN_RUNNER_SFTP_PASSWORD=
SOUN_RUNNER_HTTPS_TOKEN=

# Optional approved remote Windows credential for read-only WinRM collection.
# Do not place the plaintext value in config.yaml.
SOUN_RUNNER_REMOTE_WINDOWS_PASSWORD=

# Optional M365/Entra Graph app secret for read-only evidence collection.
SOUN_RUNNER_M365_CLIENT_SECRET=

# Optional Nessus/Tenable API keys for read-only scan export retrieval.
SOUN_RUNNER_NESSUS_ACCESS_KEY=
SOUN_RUNNER_NESSUS_SECRET_KEY=

# Optional Greenbone API password for read-only GMP access.
SOUN_RUNNER_GREENBONE_PASSWORD=

# Legacy compatibility flag for older local profiling logic.
SOUN_RUNNER_M365_CONNECTOR=false

# Assessment defaults are normally set in C:\SounRunner\config\config.yaml.
# Nmap is executed only against the authorized scope from intake/config.
